{
  "name": "jobsearch-camunda",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic job-search system — screens job leads and produces evidence-backed, ATS-optimised CVs.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/reset.ts",
    "db:demo-login": "tsx scripts/reset-demo-login.ts",
    "seed": "tsx scripts/seed.ts",
    "db:deploy": "npm run db:migrate && npm run seed && npm run db:demo-login"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "docx": "^8.5.0",
    "docxtemplater": "^3.50.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^3.4.0",
    "jose": "^5.9.6",
    "next": "^14.2.35",
    "pizzip": "^3.1.7",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "puppeteer-core": "^25.2.1",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
