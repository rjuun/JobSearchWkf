# ── Database ────────────────────────────────────────────────────────────────
# Local Postgres for dev. Same driver, same schema as production.
DATABASE_URL=postgresql://localhost:5432/jobsearch_camunda
#
# PRODUCTION (Supabase): the Vercel app runtime should use the *pooled*
# "Transaction" connection string (host …pooler.supabase.com, port 6543). The app
# detects the pooler and disables prepared statements automatically (pgbouncer
# rejects them). Example:
#   DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# DIRECT_URL — the *direct* (non-pooled) connection string (port 5432). Only the
# CLI scripts (db:migrate / seed / db:reset) use it, because migrations need
# prepared statements + session features the pooler rejects. Leave UNSET in Vercel;
# set it locally when migrating/seeding against the production database.
#   DIRECT_URL=post/Users/Fael/ju_dev/JobSearch_Camunda/.env.seed.localgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Single-user demo auth ───────────────────────────────────────────────────
APP_EMAIL=you@example.com
APP_PASSWORD=change-me
# Any long random string (used to sign the session cookie). `openssl rand -hex 32`
SESSION_SECRET=replace-with-a-32+-char-random-string

# ── LLM ─────────────────────────────────────────────────────────────────────
# Default is "live": with DEEPSEEK_API_KEY set, the pipeline uses real LLM
# judgment; with no key it safely falls back to deterministic mock fixtures.
# Set LLM_MODE=mock to force fixtures even when a key is present (demos/offline).
LLM_MODE=live

# DeepSeek (OpenAI-compatible) is the active provider. deepseek-chat supports the
# function calling our forced-tool contract needs. Get a key at platform.deepseek.com.
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat              # extraction/mapping tier (B1–B5, C2–C5)
# DEEPSEEK_MODEL_REASON=deepseek-chat       # scoring tier (B6, C7)

# ── Storage ─────────────────────────────────────────────────────────────────
# Local filesystem root for JD captures + generated CVs (gitignored).
STORAGE_DIR=.storage

# ── Production: Supabase Storage (leave blank for local dev) ─────────────────
# When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, storage switches from the
# (ephemeral on Vercel) filesystem to a Supabase Storage bucket. Create a PRIVATE
# bucket named to match SUPABASE_BUCKET (default "jobsearch"). Set these in Vercel
# AND in your local env when seeding prod (the seed uploads JDs + CVs to the bucket).
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=          # server-only — never expose to the browser / NEXT_PUBLIC_*
# SUPABASE_BUCKET=jobsearch
